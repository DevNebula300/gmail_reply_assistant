# Application
APP_NAME=Gmail Reply Assistant API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# Database (optional in phase 0 — set when implementing persistence)
DATABASE_URL=postgresql+asyncpg://gmail_assistant:gmail_assistant_dev@localhost:5432/gmail_assistant

# Redis (optional in phase 0)
REDIS_URL=redis://localhost:6379/0

# Google OAuth — create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Gmail API scopes (minimum for read + drafts)
# https://developers.google.com/gmail/api/auth/scopes
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.compose

# Session / token encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=change-me-in-production
TOKEN_ENCRYPTION_KEY=

# AI provider (phase 4)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Rate limiting
RATE_LIMIT_GENERATE_PER_HOUR=30
